# Database configuration
DATABASE_URL=postgresql://user:password@db:5432/write_db?sslmode=disable
READ_DATABASE_URL=postgresql://user:password@db:5432/read_db?sslmode=disable

# Message Broker configuration
BROKER_URL=amqp://guest:guest@broker:5672/

# Service Ports
COMMAND_SERVICE_PORT=8080
QUERY_SERVICE_PORT=8081
CONSUMER_SERVICE_PORT=8082

# Service runtime port variable consumed by binaries
PORT=8080
